{
  "hooks": [
    {
      "event": "PostToolUse",
      "match_tool_name": "WebFetch",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-research.sh",
      "async": true
    },
    {
      "event": "PostToolUse",
      "match_tool_name": "WebSearch",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-research.sh",
      "async": true
    },
    {
      "event": "PreCompact",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-session-milestones.sh",
      "async": true
    },
    {
      "event": "SessionEnd",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-session-milestones.sh",
      "async": true
    },
    {
      "event": "SubagentStop",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-session-milestones.sh",
      "async": true
    }
  ]
}
